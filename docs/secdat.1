.SH EXAMPLES
.nf
secdat set API_TOKEN --value token-123
secdat get API_TOKEN --stdout
secdat get API_TOKEN --shellescaped
secdat meta set API_TOKEN service billing
secdat meta search service=bill*
secdat meta mark-leaked BILLING_PASSWORD
secdat relation set billing-login --kind credential --member id=BILLING_ID --member password=BILLING_PASSWORD --security combination-sensitive
secdat relation search kind=credential security=combination-*
secdat relation suggest-refresh BILLING_PASSWORD
secdat relation show billing-login
secdat --dir ~/project domain create
secdat --dir ~/project-restored domain move --from ~/project
secdat --dir ~/project/service domain status
secdat --dir ~/project/service domain status --json
secdat status --json
secdat --dir ~/project --store app export
source <(secdat --dir ~/project --store app export)
secdat help inject
secdat exec --inject secret:only=APP_* --dry-run --json -- env
SECDAT_MASTER_KEY_PASSPHRASE=secret secdat unlock
secdat unlock --askpass /path/to/helper
make install-askpass-helper
SECDAT_ASKPASS=/usr/local/libexec/secdat/secdat-askpass secdat unlock --gui
secdat unlock --gui --askpass ./contrib/secdat-askpass
SECDAT_MASTER_KEY_PBKDF2_ITERATIONS=250000 secdat passwd
.fi

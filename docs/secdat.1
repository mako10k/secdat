.SH EXAMPLES
.nf
secdat set API_TOKEN --value token-123
secdat get API_TOKEN --stdout
secdat get API_TOKEN --shellescaped
secdat --dir ~/project domain create
secdat --dir ~/project --store app export
source <(secdat --dir ~/project --store app export)
SECDAT_MASTER_KEY_PASSPHRASE=secret secdat unlock
.fi

#: src/cli.c:209
#, c-format
msgid ""
"\n"
"Groups:\n"
msgstr ""
"\n"
"グループ:\n"

#: src/cli.c:210
#, c-format
msgid "  store: manage store namespaces inside the resolved current domain\n"
msgstr "  store: 解決された current domain 内の store namespace を管理します\n"

#: src/cli.c:211
#, c-format
msgid "  domain: manage domain roots and domain discovery scope\n"
msgstr "  domain: domain root と domain 探索スコープを管理します\n"

#: src/cli.c:216
#, c-format
msgid ""
"\n"
"Commands:\n"
msgstr ""
"\n"
"コマンド:\n"

#: src/cli.c:217
#, c-format
msgid "  help: show global help or detailed help for one command\n"
msgstr "  help: 全体ヘルプ、または 1 つのコマンドの詳細ヘルプを表示します\n"

#: src/cli.c:218
#, c-format
msgid "  ls: list effective keys visible from the current domain view\n"
msgstr "  ls: 現在の domain view から見える有効な key を一覧します\n"

#: src/cli.c:219
#, c-format
msgid "  get: decrypt one resolved key and write it to standard output\n"
msgstr "  get: 解決された 1 つの key を復号して標準出力へ書き出します\n"

#: src/cli.c:220
#, c-format
msgid "  set: store or update one key in the resolved current domain\n"
msgstr ""
"  set: 解決された current domain に 1 つの key を保存または更新します\n"

#: src/cli.c:221
#, c-format
msgid ""
"  rm: remove one key locally or create a tombstone for an inherited key\n"
msgstr ""
"  rm: 1 つの key をローカルに削除するか、継承 key 用の tombstone を作成しま"
"す\n"

#: src/cli.c:222
#, c-format
msgid "  mv: rename or relocate one key between resolved locations\n"
msgstr "  mv: 1 つの key を解決先の場所どうしで改名または移動します\n"

#: src/cli.c:223
#, c-format
msgid "  cp: copy one key into another resolved location\n"
msgstr "  cp: 1 つの key を別の解決先へコピーします\n"

#: src/cli.c:224
#, c-format
msgid "  exec: inject resolved keys into a child process environment\n"
msgstr "  exec: 解決された key を子プロセス環境へ注入します\n"

#: src/cli.c:225
#, c-format
msgid "  unlock: start or refresh an authenticated secret session\n"
msgstr "  unlock: 認証済み secret session を開始または更新します\n"

#: src/cli.c:226
#, c-format
msgid "  lock: clear the active secret session\n"
msgstr "  lock: 現在の secret session を消去します\n"

#: src/cli.c:227
#, c-format
msgid "  status: report whether secret material is currently available\n"
msgstr "  status: 現在 secret material が利用可能かどうかを報告します\n"

#: src/cli.c:228
#, c-format
msgid "  version: print the secdat version\n"
msgstr "  version: secdat のバージョンを表示します\n"

#: src/cli.c:233
#, c-format
msgid ""
"\n"
"Meaning:\n"
msgstr ""
"\n"
"意味:\n"


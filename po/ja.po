"Support:\n"
msgstr ""
"\n"
"サポート:\n"

#: src/cli.c:267
#, c-format
msgid "  issues: https://github.com/mako10k/secdat/issues\n"
msgstr "  issue 報告先: https://github.com/mako10k/secdat/issues\n"

#: src/cli.c:268
#, c-format

#: src/cli.c:165
#, c-format
msgid "  %s [-d DIR|--dir DIR] domain create\n"
msgstr "  %s [-d DIR|--dir DIR] domain create\n"

#: src/cli.c:168
#, c-format
msgid "  %s [-d DIR|--dir DIR] domain delete\n"
msgstr "  %s [-d DIR|--dir DIR] domain delete\n"

#: src/cli.c:171

msgid ""
"\n"
"Semantics:\n"
msgstr ""
"\n"
"セマンティクス:\n"

#: src/cli.c:356
#, c-format
msgid ""
"  DIR: base directory used for domain resolution; defaults to the current "
"working directory\n"
msgstr ""
"  DIR: domain 解決の基準ディレクトリです。省略時は現在の作業ディレクトリを使"
"います\n"

#: src/cli.c:357
#, c-format
msgid ""
"  DOMAIN: directory-scoped configuration boundary used for inheritance and "
"tombstones\n"
msgstr "  DOMAIN: 継承と tombstone に使う、ディレクトリ単位の設定境界です\n"

#: src/cli.c:358
#, c-format
msgid ""
"  STORE: domain-local namespace selected by --store; defaults to the default "
"store\n"
msgstr ""
"  STORE: --store で選ぶ domain ローカルな名前空間です。省略時は default "
"store を使います\n"

#: src/cli.c:359
#, c-format
msgid ""
"  KEY / KEYREF: logical secret name, optionally qualified as KEY[/ABSOLUTE/"
"DOMAIN][:STORE]\n"
msgstr ""
"  KEY / KEYREF: 論理的な secret 名です。必要なら KEY[/ABSOLUTE/DOMAIN][:"
"STORE] で修飾できます\n"


#: src/cli.c:13
#, c-format
msgid "missing value for --dir\n"
msgstr "--dir に値が必要です\n"

#: src/cli.c:23
#, c-format
msgid "missing value for --store\n"
msgstr "--store に値が必要です\n"

#: src/cli.c:71
#, c-format
msgid "missing store subcommand\n"
msgstr "store サブコマンドが必要です\n"

#: src/cli.c:85
#, c-format
msgid "unknown store subcommand: %s\n"
msgstr "不明な store サブコマンドです: %s\n"


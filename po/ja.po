msgstr ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] cp SRC_KEYREF DST_KEYREF\n"

#: src/cli.c:144
#, c-format
msgid ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] exec [-p GLOBPATTERN|--"
"pattern GLOBPATTERN] CMD [ARGS...]\n"
msgstr ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] exec [-p GLOBPATTERN|--"
"pattern GLOBPATTERN] CMD [ARGS...]\n"

#: src/cli.c:147

"\n"
"Shell:\n"
msgstr ""
"\n"
"シェル:\n"

#: src/cli.c:1035
#, c-format
msgid "  bash load current shell vars: source <(%s export)\n"
msgstr "  bash で現在の shell に読み込む: source <(%s export)\n"

#: src/cli.c:1037
#, c-format

#: src/cli.c:227
#, c-format
msgid ""
"\n"
"Groups:\n"
msgstr ""
"\n"
"グループ:\n"

#: src/cli.c:228
#, c-format
msgid "  store: manage store namespaces inside the resolved current domain\n"
msgstr "  store: 解決された current domain 内の store namespace を管理します\n"

#: src/cli.c:229
#, c-format
msgid "  domain: manage domain roots and domain discovery scope\n"
msgstr "  domain: domain root と domain 探索スコープを管理します\n"

#: src/cli.c:234
#, c-format
msgid ""
"\n"
"Commands:\n"
msgstr ""
"\n"
"コマンド:\n"

#: src/cli.c:235
#, c-format
msgid "  help: show global help or detailed help for one command\n"
msgstr "  help: 全体ヘルプ、または 1 つのコマンドの詳細ヘルプを表示します\n"

#: src/cli.c:236
#, c-format
msgid "  ls: list effective keys visible from the current domain view\n"
msgstr "  ls: 現在の domain view から見える有効な key を一覧します\n"

#: src/cli.c:237
#, c-format
msgid "  get: decrypt one resolved key and write it to standard output\n"
msgstr "  get: 解決された 1 つの key を復号して標準出力へ書き出します\n"

#: src/cli.c:238
#, c-format
msgid "  set: store or update one key in the resolved current domain\n"
msgstr ""
"  set: 解決された current domain に 1 つの key を保存または更新します\n"

#: src/cli.c:239
#, c-format
msgid ""
"  rm: remove one key locally or create a tombstone for an inherited key\n"
msgstr ""
"  rm: 1 つの key をローカルに削除するか、継承 key 用の tombstone を作成しま"
"す\n"

#: src/cli.c:240
#, c-format
msgid "  mv: rename or relocate one key between resolved locations\n"
msgstr "  mv: 1 つの key を解決先の場所どうしで改名または移動します\n"

#: src/cli.c:241
#, c-format
msgid "  cp: copy one key into another resolved location\n"
msgstr "  cp: 1 つの key を別の解決先へコピーします\n"

#: src/cli.c:242
#, c-format
msgid "  exec: inject resolved keys into a child process environment\n"
msgstr "  exec: 解決された key を子プロセス環境へ注入します\n"

#: src/cli.c:243
#, c-format
msgid ""
"  export: emit shell-ready export lines that defer secret reads to secdat "
"get\n"
msgstr ""
"  export: secret の読み出しを secdat get に委ねる shell 向け export 行を出力"
"します\n"

#: src/cli.c:244
#, c-format
msgid ""
"  save: export the current visible secrets into a passphrase-protected "
"bundle\n"
msgstr ""
"  save: 現在の view から見える secret をパスフレーズ保護された bundle として"
"出力します\n"

#: src/cli.c:245
#, c-format
msgid ""
"  load: import a passphrase-protected bundle into the current domain view\n"
msgstr ""
"  load: パスフレーズ保護された bundle を現在の domain view に取り込みます\n"

#: src/cli.c:246
#, c-format
msgid "  unlock: start or refresh an authenticated secret session\n"
msgstr "  unlock: 認証済み secret session を開始または更新します\n"

#: src/cli.c:247
#, c-format
msgid "  lock: clear the active secret session\n"
msgstr "  lock: 現在の secret session を消去します\n"

#: src/cli.c:248
#, c-format
msgid "  status: report whether secret material is currently available\n"
msgstr "  status: 現在 secret material が利用可能かどうかを報告します\n"

#: src/cli.c:249
#, c-format
msgid "  version: print the secdat version\n"
msgstr "  version: secdat のバージョンを表示します\n"

#: src/cli.c:254
#, c-format
msgid ""
"\n"
"Meaning:\n"
msgstr ""
"\n"
"意味:\n"

#: src/cli.c:256
#, c-format
msgid "  show global help or detailed help for one command\n"
msgstr "  全体ヘルプ、または 1 つのコマンドの詳細ヘルプを表示します\n"

#: src/cli.c:260
#, c-format
msgid "  list effective keys visible from the current domain view\n"
msgstr "  現在の domain view から見える有効な key を一覧します\n"

#: src/cli.c:264
#, c-format
msgid "  decrypt one resolved key and write it to standard output\n"
msgstr "  解決された 1 つの key を復号して標準出力へ書き出します\n"

#: src/cli.c:268
#, c-format
msgid "  store or update one key in the resolved current domain\n"
msgstr "  解決された current domain に 1 つの key を保存または更新します\n"

#: src/cli.c:272
#, c-format
msgid "  remove one key locally or create a tombstone for an inherited key\n"
msgstr ""
"  1 つの key をローカルに削除するか、継承 key 用の tombstone を作成します\n"

#: src/cli.c:276
#, c-format
msgid "  rename or relocate one key between resolved locations\n"
msgstr "  1 つの key を解決先の場所どうしで改名または移動します\n"

#: src/cli.c:280
#, c-format
msgid "  copy one key into another resolved location\n"
msgstr "  1 つの key を別の解決先へコピーします\n"

#: src/cli.c:284
#, c-format
msgid "  inject resolved keys into a child process environment\n"
msgstr "  解決された key を子プロセス環境へ注入します\n"

#: src/cli.c:288
#, c-format
msgid "  emit shell-ready export lines that defer secret reads to secdat get\n"
msgstr ""
"  secret の読み出しを secdat get に委ねる shell 向け export 行を出力します\n"

#: src/cli.c:292
#, c-format
msgid ""
"  export the current visible secrets into a passphrase-protected bundle\n"
msgstr ""
"  現在の view から見える secret をパスフレーズ保護された bundle として出力し"
"ます\n"

#: src/cli.c:296
#, c-format
msgid "  import a passphrase-protected bundle into the current domain view\n"
msgstr "  パスフレーズ保護された bundle を現在の domain view に取り込みます\n"

#: src/cli.c:300
#, c-format
msgid "  start or refresh an authenticated secret session\n"
msgstr "  認証済み secret session を開始または更新します\n"

#: src/cli.c:304
#, c-format
msgid "  clear the active secret session\n"
msgstr "  現在の secret session を消去します\n"

#: src/cli.c:308
#, c-format
msgid "  report whether secret material is currently available\n"
msgstr "  現在 secret material が利用可能かどうかを報告します\n"

#: src/cli.c:312
#, c-format
msgid "  print the secdat version\n"
msgstr "  secdat のバージョンを表示します\n"

#: src/cli.c:316
#, c-format
msgid "  manage store namespaces inside the resolved current domain\n"
msgstr "  解決された current domain 内の store namespace を管理します\n"

#: src/cli.c:320
#, c-format
msgid "  manage domain roots and domain discovery scope\n"
msgstr "  domain root と domain 探索スコープを管理します\n"

#: src/cli.c:327
#, c-format
msgid ""
"\n"
"Semantics:\n"
msgstr ""
"\n"
"セマンティクス:\n"

#: src/cli.c:328
#, c-format
msgid ""
"  DIR: base directory used for domain resolution; defaults to the current "
"working directory\n"
msgstr ""
"  DIR: domain 解決の基準ディレクトリです。省略時は現在の作業ディレクトリを使"
"います\n"

#: src/cli.c:329
#, c-format
msgid ""
"  DOMAIN: directory-scoped configuration boundary used for inheritance and "
"tombstones\n"
msgstr "  DOMAIN: 継承と tombstone に使う、ディレクトリ単位の設定境界です\n"

#: src/cli.c:330
#, c-format
msgid ""
"  STORE: domain-local namespace selected by --store; defaults to the default "
"store\n"
msgstr ""
"  STORE: --store で選ぶ domain ローカルな名前空間です。省略時は default "
"store を使います\n"

#: src/cli.c:331
#, c-format
msgid ""
"  KEY / KEYREF: logical secret name, optionally qualified as KEY[/ABSOLUTE/"
"DOMAIN][:STORE]\n"
msgstr ""
"  KEY / KEYREF: 論理的な secret 名です。必要なら KEY[/ABSOLUTE/DOMAIN][:"
"STORE] で修飾できます\n"

#: src/cli.c:435
#, c-format
msgid "unknown store subcommand: %s\n"
msgstr "不明な store サブコマンドです: %s\n"

#: src/cli.c:462
#, c-format
msgid "unknown domain subcommand: %s\n"
msgstr "不明な domain サブコマンドです: %s\n"

#: src/cli.c:466
#, c-format
msgid "unknown command: %s\n"
msgstr "不明なコマンドです: %s\n"


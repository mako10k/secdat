#, c-format
msgid "missing value for --domain\n"
msgstr "--domain に値が必要です\n"

#: src/cli.c:331 src/cli.c:337
#, c-format
msgid "missing value for --store\n"
msgstr "--store に値が必要です\n"

#: src/cli.c:339
#, c-format
msgid "missing option value\n"
msgstr "オプション値が不足しています\n"


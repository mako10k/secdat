msgstr "  %s コマンド名 --help\n"

#: src/cli.c:1023
#, c-format
msgid "  %s --help %s\n"
msgstr "  %s --help %s\n"

#: src/cli.c:1024
#, c-format
msgid "  %s %s --help\n"
msgstr "  %s %s --help\n"

#: src/cli.c:1026

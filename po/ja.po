msgstr "  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] unmask KEYREF\n"

#: src/cli.c:150
#, c-format
msgid "  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] exists KEYREF\n"
msgstr "  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] exists KEYREF\n"

#: src/cli.c:153
#, c-format
msgid ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] get [--on-demand-unlock] [--"
"unlock-timeout SECONDS] KEYREF [-o|--stdout|--shellescaped]\n"
msgstr ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] get [--on-demand-unlock] [--"
"unlock-timeout SECONDS] KEYREF [-o|--stdout|--shellescaped]\n"

#: src/cli.c:156
#, c-format
msgid ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] set KEYREF [--unsafe] "

#, c-format
msgid ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] get KEYREF [-o|--stdout|--"
"shellescaped]\n"
msgstr ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] get KEYREF [-o|--stdout|--"
"shellescaped]\n"


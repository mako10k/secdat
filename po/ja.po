msgstr "  author: Makoto Katsumata <mako10k@mk10.org>\n"

#: src/cli.c:274
#, c-format
msgid ""
"\n"
"Groups:\n"
msgstr ""
"\n"
"グループ:\n"

#: src/cli.c:275
#, c-format
msgid "  store: manage store namespaces inside the resolved current domain\n"
msgstr "  store: 解決された current domain 内の store namespace を管理します\n"

#: src/cli.c:276
#, c-format
msgid "  domain: manage domain roots and domain discovery scope\n"
msgstr "  domain: domain root と domain 探索スコープを管理します\n"

#: src/cli.c:281
#, c-format
msgid ""
"\n"
"Commands:\n"
msgstr ""
"\n"
"コマンド:\n"

#: src/cli.c:282
#, c-format
msgid "  help: show global help or detailed help for one command\n"
msgstr "  help: 全体ヘルプ、または 1 つのコマンドの詳細ヘルプを表示します\n"

#: src/cli.c:283
#, c-format
msgid ""
"  ls: list effective keys visible from the current domain view, optionally "
"filtered by safe or unsafe storage\n"
msgstr ""
"  ls: 現在の domain view から見える有効な key を、安全または unsafe な保存方"
"式で絞り込んで一覧します\n"

#: src/cli.c:284
#, c-format
msgid ""
"  list: inspect current-domain masked, overridden, orphaned, safe, or unsafe "
"local state\n"
msgstr ""
"  list: 現在の domain の masked・overridden・orphaned・safe・unsafe な local "
"state を確認します\n"

#: src/cli.c:285
#, c-format
msgid "  mask: create a local tombstone to hide one inherited key\n"
msgstr "  mask: 継承された 1 つの key を隠す local tombstone を作成します\n"

#: src/cli.c:286
#, c-format
msgid "  unmask: remove one local tombstone from the current domain\n"
msgstr "  unmask: 現在の domain から 1 つの local tombstone を削除します\n"

#: src/cli.c:287
#, c-format
msgid ""
"  exists: check whether one resolved key is visible from the current domain "
"view\n"
msgstr ""
"  exists: 解決された 1 つの key が現在の domain view から見えるか確認します\n"

#: src/cli.c:288
#, c-format
msgid "  get: decrypt one resolved key and write it to standard output; --on-demand-unlock waits for another terminal to unlock\n"
msgstr "  get: 解決された 1 つの key を復号して標準出力へ書き出します。--on-demand-unlock を付けると別端末での unlock を待機します\n"

#: src/cli.c:289
#, c-format
msgid ""
"  set: store or update one key in the resolved current domain; --unsafe "
"stores plaintext visible while locked\n"
msgstr ""
"  set: 解決された current domain に 1 つの key を保存または更新します。--"
"unsafe は lock 中も見える平文を保存します\n"

#: src/cli.c:290
#, c-format
msgid ""
"  rm: remove one key locally or create a tombstone for an inherited key; --"
"ignore-missing treats absent keys as success\n"
msgstr ""
"  rm: 1 つの key をローカルに削除するか、継承 key 用の tombstone を作成しま"
"す。--ignore-missing は未存在の key を成功扱いにします\n"

#: src/cli.c:291
#, c-format
msgid "  mv: rename or relocate one key between resolved locations\n"
msgstr "  mv: 1 つの key を解決先の場所どうしで改名または移動します\n"

#: src/cli.c:292
#, c-format
msgid "  cp: copy one key into another resolved location\n"
msgstr "  cp: 1 つの key を別の解決先へコピーします\n"

#: src/cli.c:293
#, c-format
msgid "  exec: inject resolved keys into a child process environment\n"
msgstr "  exec: 解決された key を子プロセス環境へ注入します\n"

#: src/cli.c:294
#, c-format
msgid ""
"  export: emit shell-ready export lines that defer secret reads to secdat "
"get\n"
msgstr ""
"  export: secret の読み出しを secdat get に委ねる shell 向け export 行を出力"
"します\n"

#: src/cli.c:295
#, c-format
msgid ""
"  save: export the current visible secrets into a passphrase-protected "
"bundle\n"
msgstr ""
"  save: 現在の view から見える secret をパスフレーズ保護された bundle として"
"出力します\n"

#: src/cli.c:296
#, c-format
msgid ""
"  load: import a passphrase-protected bundle into the current domain view\n"
msgstr ""
"  load: パスフレーズ保護された bundle を現在の domain view に取り込みます\n"

#: src/cli.c:297
#, c-format
msgid ""
"  unlock: start or refresh an authenticated secret session for the current "
"domain; --inherit removes a local explicit-lock marker or clears a local "
"session when no marker is present\n"
msgstr ""
"  unlock: 現在の domain 用の認証済み secret session を開始または更新します。"
"--inherit は local explicit-lock marker を削除するか、marker がなければ "
"local session を消去します\n"

#: src/cli.c:298
#, c-format
msgid "  inherit: remove the current domain's local explicit-lock marker, or clear a local session when no marker is present, without checking the resulting state\n"
msgstr "  inherit: 結果状態を確認せず、現在の domain の local explicit-lock marker を削除するか、marker がなければ local session を消去します\n"

#: src/cli.c:299
#, c-format
msgid "  passwd: change the wrapped-master-key passphrase\n"
msgstr "  passwd: ラップ済み master key のパスフレーズを変更します\n"

#: src/cli.c:300
#, c-format
msgid "  lock: clear the current domain's local secret session\n"
msgstr "  lock: 現在の domain の local secret session を消去します\n"

#: src/cli.c:300
#, c-format
msgid ""
"  status: report whether secret material is available from the current "
"domain scope\n"
msgstr ""
"  status: 現在の domain scope から secret material が利用可能かどうかを報告し"
"ます\n"

#: src/cli.c:301
#, c-format
msgid "  version: print the secdat version\n"
msgstr "  version: secdat のバージョンを表示します\n"

#: src/cli.c:306
#, c-format
msgid ""
"\n"
"Meaning:\n"
msgstr ""
"\n"
"意味:\n"

#: src/cli.c:308
#, c-format
msgid "  show global help or detailed help for one command\n"
msgstr "  全体ヘルプ、または 1 つのコマンドの詳細ヘルプを表示します\n"

#: src/cli.c:312
#, c-format
msgid ""
"  list effective keys visible from the current domain view, optionally "
"filtered by safe or unsafe storage\n"
msgstr ""
"  現在の domain view から見える有効な key を、安全または unsafe な保存方式で"
"絞り込んで一覧します\n"

#: src/cli.c:316
#, c-format
msgid ""
"  inspect current-domain masked, overridden, orphaned, safe, or unsafe local "
"state\n"
msgstr ""
"  現在の domain の masked・overridden・orphaned・safe・unsafe な local state "
"を確認します\n"

#: src/cli.c:320
#, c-format
msgid "  create a local tombstone to hide one inherited key\n"
msgstr "  継承された 1 つの key を隠す local tombstone を作成します\n"

#: src/cli.c:324
#, c-format
msgid "  remove one local tombstone from the current domain\n"
msgstr "  現在の domain から 1 つの local tombstone を削除します\n"

#: src/cli.c:328
#, c-format
msgid ""
"  check whether one resolved key is visible from the current domain view\n"
msgstr "  解決された 1 つの key が現在の domain view から見えるか確認します\n"

#: src/cli.c:332
#, c-format
msgid "  decrypt one resolved key and write it to standard output; --on-demand-unlock waits for another terminal to unlock\n"
msgstr "  解決された 1 つの key を復号して標準出力へ書き出します。--on-demand-unlock を付けると別端末での unlock を待機します\n"

#: src/store.c:0
#, c-format
msgid "missing value for --unlock-timeout\n"
msgstr "--unlock-timeout に値が必要です\n"

#: src/store.c:0
#, c-format
msgid "invalid value for --unlock-timeout: %s\n"
msgstr "--unlock-timeout の値が不正です: %s\n"

#: src/store.c:0
#, c-format
msgid "--unlock-timeout requires --on-demand-unlock or %s\n"
msgstr "--unlock-timeout を使うには --on-demand-unlock または %s が必要です\n"

#: src/store.c:0
#, c-format
msgid "waiting for another terminal to unlock secrets for resolved domain: %s\n"
msgstr "別端末で secrets が unlock されるのを待機しています。解決済み domain: %s\n"

#: src/store.c:0
#, c-format
msgid "unlock from another terminal: secdat unlock\n"
msgstr "別端末で unlock: secdat unlock\n"

#: src/store.c:0
#, c-format
msgid "unlock from another terminal: secdat --dir %s unlock\n"
msgstr "別端末で unlock: secdat --dir %s unlock\n"

#: src/store.c:0
#, c-format
msgid "unlock wait timeout: %lld seconds\n"
msgstr "unlock 待機タイムアウト: %lld 秒\n"

#: src/store.c:0
#, c-format
msgid "timed out waiting for another terminal to unlock secrets after %lld seconds\n"
msgstr "別端末での secrets の unlock 待機が %lld 秒でタイムアウトしました\n"

#: src/cli.c:336
#, c-format
msgid ""
"  store or update one key in the resolved current domain; --unsafe stores "
"plaintext visible while locked\n"
msgstr ""
"  解決された current domain に 1 つの key を保存または更新します。--unsafe "
"は lock 中も見える平文を保存します\n"

#: src/cli.c:340
#, c-format
msgid ""
"  remove one key locally or create a tombstone for an inherited key; --"
"ignore-missing treats absent keys as success\n"
msgstr ""
"  1 つの key をローカルに削除するか、継承 key 用の tombstone を作成します。--"
"ignore-missing は未存在の key を成功扱いにします\n"

#: src/cli.c:344
#, c-format
msgid "  rename or relocate one key between resolved locations\n"
msgstr "  1 つの key を解決先の場所どうしで改名または移動します\n"

#: src/cli.c:348
#, c-format
msgid "  copy one key into another resolved location\n"
msgstr "  1 つの key を別の解決先へコピーします\n"

#: src/cli.c:352
#, c-format
msgid "  inject resolved keys into a child process environment\n"
msgstr "  解決された key を子プロセス環境へ注入します\n"

#: src/cli.c:356

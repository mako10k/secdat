#: src/cli.c:186
#, c-format
msgid "  %s [options] subcommand ...\n"
msgstr "  %s [オプション] サブコマンド ...\n"

#: src/cli.c:191
#, c-format
msgid ""
"\n"
"Options:\n"
msgstr ""
"\n"
"オプション:\n"

#: src/cli.c:192
#, c-format
msgid ""
"  -d, --dir DIR      set the base directory used for domain resolution\n"
msgstr "  -d, --dir DIR      domain 解決に使う基準ディレクトリを指定します\n"

#: src/cli.c:193
#, c-format
msgid ""
"  -s, --store STORE  select the store namespace inside the resolved domain\n"
msgstr ""
"  -s, --store STORE  解決された domain 内で使う store namespace を選択しま"
"す\n"

#: src/cli.c:194
#, c-format
msgid ""
"  -h, --help         show global help, or combine with COMMAND for detailed "
"help\n"
msgstr ""
"  -h, --help         全体ヘルプを表示します。COMMAND と組み合わせると詳細ヘル"
"プを表示します\n"

#: src/cli.c:195
#, c-format
msgid "  -V, --version      print the secdat version\n"
msgstr "  -V, --version      secdat のバージョンを表示します\n"

#: src/cli.c:201 src/cli.c:213
#, c-format
msgid "  %s help [COMMAND]\n"
msgstr "  %s help [コマンド名]\n"

#: src/cli.c:205 src/cli.c:222
#, c-format
msgid "  %s version\n"
msgstr "  %s version\n"

#: src/cli.c:211
#, c-format
msgid ""
"\n"
"Help:\n"
msgstr ""
"\n"
"ヘルプ:\n"

#: src/cli.c:212
#, c-format
msgid "  %s --help\n"
msgstr "  %s --help\n"

#: src/cli.c:215
#, c-format
msgid "  %s --help COMMAND\n"
msgstr "  %s --help コマンド名\n"

#: src/cli.c:216
#, c-format
msgid "  %s COMMAND --help\n"
msgstr "  %s コマンド名 --help\n"

#: src/cli.c:218
#, c-format
msgid "  %s --help %s\n"
msgstr "  %s --help %s\n"


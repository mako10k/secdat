#: src/cli.c:129
#, c-format
msgid ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] ls [GLOBPATTERN] [-p "
"GLOBPATTERN|--pattern GLOBPATTERN] [--pattern-exclude GLOBPATTERN] [-c|--"
"canonical] [-D|--canonical-domain] [-S|--canonical-store]\n"
msgstr ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] ls [GLOBPATTERN] [-p "
"GLOBPATTERN|--pattern GLOBPATTERN] [--pattern-exclude GLOBPATTERN] [-c|--"
"canonical] [-D|--canonical-domain] [-S|--canonical-store]\n"


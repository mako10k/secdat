msgstr "  %s コマンド名 --help\n"

#: src/cli.c:581
#, c-format
msgid "  %s --help %s\n"
msgstr "  %s --help %s\n"

#: src/cli.c:582
#, c-format
msgid "  %s %s --help\n"
msgstr "  %s %s --help\n"


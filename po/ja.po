#: src/cli.c:43 src/cli.c:47
#, c-format
msgid "missing value for --dir\n"
msgstr "--dir に値が必要です\n"

#: src/cli.c:45 src/cli.c:49
#, c-format
msgid "missing value for --store\n"
msgstr "--store に値が必要です\n"

#: src/cli.c:51
#, c-format
msgid "missing option value\n"
msgstr "オプション値が不足しています\n"

#: src/cli.c:55
#, c-format
msgid "unknown option: %s\n"
msgstr "不明なオプションです: %s\n"

#: src/cli.c:123
#, c-format
msgid ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] ls [GLOBPATTERN] [-p "
"GLOBPATTERN|--pattern GLOBPATTERN] [-c|--canonical] [-D|--canonical-domain] "
"[-S|--canonical-store]\n"
msgstr ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] ls [GLOBPATTERN] [-p "
"GLOBPATTERN|--pattern GLOBPATTERN] [-c|--canonical] [-D|--canonical-domain] "
"[-S|--canonical-store]\n"

#: src/cli.c:126
#, c-format
msgid ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] get KEYREF [-o|--stdout|--"
"shellescaped]\n"
msgstr ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] get KEYREF [-o|--stdout|--"
"shellescaped]\n"

#: src/cli.c:129
#, c-format
msgid ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] set KEYREF [VALUE|-i|--"
"stdin|-e ENVNAME|--env ENVNAME|-v VALUE|--value VALUE]\n"
msgstr ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] set KEYREF [VALUE|-i|--"
"stdin|-e ENVNAME|--env ENVNAME|-v VALUE|--value VALUE]\n"

#: src/cli.c:132
#, c-format
msgid "  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] rm KEYREF\n"
msgstr "  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] rm KEYREF\n"

#: src/cli.c:135
#, c-format
msgid ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] mv SRC_KEYREF DST_KEYREF\n"
msgstr ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] mv SRC_KEYREF DST_KEYREF\n"

#: src/cli.c:138
#, c-format
msgid ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] cp SRC_KEYREF DST_KEYREF\n"
msgstr ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] cp SRC_KEYREF DST_KEYREF\n"

#: src/cli.c:141
#, c-format
msgid ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] exec [-p GLOBPATTERN|--"
"pattern GLOBPATTERN] CMD [ARGS...]\n"
msgstr ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] exec [-p GLOBPATTERN|--"
"pattern GLOBPATTERN] CMD [ARGS...]\n"

#: src/cli.c:144
#, c-format
msgid ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] export [-p GLOBPATTERN|--"
"pattern GLOBPATTERN]\n"
msgstr ""
"  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] export [-p GLOBPATTERN|--"
"pattern GLOBPATTERN]\n"

#: src/cli.c:147
#, c-format
msgid "  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] save FILE\n"
msgstr "  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] save FILE\n"

#: src/cli.c:150
#, c-format
msgid "  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] load FILE\n"
msgstr "  %s [-d DIR|--dir DIR] [-s STORE|--store STORE] load FILE\n"

